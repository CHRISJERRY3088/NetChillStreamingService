# NetChill Backend Configuration
# Copy this file to .env and fill in your values

# Server Port
PORT=3000

# Supabase Project URL and Service Role Key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT Secret (use a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Node Environment
NODE_ENV=production

# Client URL (for CORS and redirects)
CLIENT_URL=http://localhost:3000

# Resend Email Service (Optional)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@netchill.com
EMAIL_FROM_NAME=NetChill

# Flutterwave Payment
# Test keys from Flutterwave dashboard
FLW_PUBLIC_KEY=FLWPUBK_TEST_xxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST_xxxxxxxxxxxxxxxxxxxxxxxx-X
# Set this to your webhook hash from Flutterwave webhook settings
FLW_WEBHOOK_HASH=your_flutterwave_webhook_hash
# Currency used for subscription checkout (USD/NGN/etc.)
FLW_CURRENCY=USD
